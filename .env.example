# Copy this to .env (gitignored) and fill in real values.
# Required for full functionality; v1 will degrade gracefully if any are missing.

# Anthropic — for Claude Code itself (sandbox usage)
ANTHROPIC_API_KEY=

# ComputePrices — request a free 5k/hr key by emailing api@computeprices.com.
# Anonymous tier (60 req/hr per IP) works for initial development; runs out fast in tests.
COMPUTEPRICES_API_KEY=

# Artificial Analysis — optional. Sign up at artificialanalysis.ai/login.
# Free tier: 1,000 req/day. Without it, M04 is feature-flagged off and the
# rest of the system works unchanged.
AA_API_KEY=

# Hugging Face — optional. Improves rate limits on config.json fetches.
# Without it, anonymous tier suffices for ~30 model syncs/day.
HF_TOKEN=
